{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run Barberia Backend",
            "type": "shell",
            "command": "java",
            "args": [
                "-jar",
                "${workspaceFolder}/backend/target/barberia-service-1.0.0.jar"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "isBackground": true,
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "problemMatcher": {
                "pattern": {
                    "regexp": "^.*$",
                    "file": 1,
                    "location": 2,
                    "message": 3
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^.*Started.*$",
                    "endsPattern": "^.*Tomcat started.*$"
                }
            }
        },
        {
            "label": "Build Barberia Backend",
            "type": "shell",
            "command": "mvn",
            "args": [
                "clean",
                "package",
                "-DskipTests"
            ],
            "options": {
                "cwd": "${workspaceFolder}/backend"
            },
            "group": {
                "kind": "build"
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": "$maven"
        }
    ]
}
